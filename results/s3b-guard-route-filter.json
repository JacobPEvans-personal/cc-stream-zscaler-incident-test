      "actual": {
        "zscaler/zscalernss-web": 334,
        "zscaler/zscalernss-fw": 333,
        "zscaler/zscalernss-dns": 333
      },
      "expected": {
        "zscaler/zscalernss-web": 334,
        "zscaler/zscalernss-fw": 333,
        "zscaler/zscalernss-dns": 333
      },
      "live": 46
    },
    "s3": {
      "actual": {
        "zscaler/zscalernss-web": 334,
        "zscaler/zscalernss-fw": 333,
        "zscaler/zscalernss-dns": 333
      },
      "expected": {
        "zscaler/zscalernss-web": 334,
        "zscaler/zscalernss-fw": 333,
        "zscaler/zscalernss-dns": 333
      },
      "live": 46
    },
    "dev": {
      "actual": {},
      "expected": {},
      "live": 0
    },
    "default": {
      "actual": {},
      "expected": {},
      "live": 0
    }
  },
  "pass": true
}
